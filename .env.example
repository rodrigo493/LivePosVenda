# ==============================================================================
# Live Care — Variaveis de Ambiente (TEMPLATE)
# ==============================================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no repositorio.
# ==============================================================================

# --- Frontend (Supabase) ---
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# --- SquadOS Workflow Integration ---
VITE_SQUAD_API_URL=https://squad.liveuni.com.br
VITE_SQUAD_WORKFLOW_API_KEY=                    # API key do SquadOS para criação de itens de fluxo
VITE_SQUAD_POSVENDA_TEMPLATE_ID=               # ID do template "Fluxo Pós Venda" no SquadOS

# --- Server-side (configurar no Supabase Dashboard > Edge Functions > Env Vars) ---
# AI_API_KEY=                    # OpenRouter — https://openrouter.ai/keys
# WHATSAPP_ACCESS_TOKEN=         # WhatsApp Cloud API
# WHATSAPP_PHONE_NUMBER_ID=      # WhatsApp Phone Number ID
# WHATSAPP_VERIFY_TOKEN=         # WhatsApp Webhook Verify Token
# NOMUS_API_KEY=                 # Nomus ERP API Key
# NOMUS_PROXY_URL=               # Nomus Proxy URL
# NOMUS_PROXY_SECRET=            # Nomus Proxy Secret
