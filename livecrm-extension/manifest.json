{
  "manifest_version": 3,
  "name": "LiveCRM WhatsApp",
  "version": "1.1.0",
  "version_name": "1.1.0",
  "description": "Integra o WhatsApp Web com o LiveCRM — captura mensagens e envia pelo painel.",
  "minimum_chrome_version": "95",
  "permissions": ["storage", "alarms", "scripting", "tabs", "windows", "notifications"],
  "host_permissions": ["https://web.whatsapp.com/*", "https://posvenda.liveuni.com.br/*", "https://api-free.deepl.com/*"],
  "externally_connectable": {
    "matches": ["https://posvenda.liveuni.com.br/*"]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["lib/supabase-umd.js", "config.js", "content_script.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["wa_hook.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://posvenda.liveuni.com.br/*"],
      "js": ["crm_bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LiveCRM Status",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'"
  }
}
